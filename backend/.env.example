# ColorInsight Backend Environment Configuration Template
# Copy this file to .env and fill in your values

# Development mode (set to 'true' for local testing, 'false' for production)
DEV_MODE=false

# Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Image Generation API (apicore.ai)
IMAGE_API_KEY=your_image_api_key_here
IMAGE_API_ENDPOINT=https://api.apicore.ai/v1/chat/completions
IMAGE_MODEL=gemini-3-pro-image-preview-4k

# JWT Secret (use the same secret as main portal for authentication)
JWT_SECRET=your_jwt_secret_here
